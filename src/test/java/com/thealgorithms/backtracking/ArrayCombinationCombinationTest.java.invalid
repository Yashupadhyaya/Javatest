import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import java.util.List;
import java.util.TreeSet;
import static org.junit.jupiter.api.Assertions.*;

class ArrayCombinationCombinationTest {
  @Test
  @Tag("Valid")
  void testValidCombination() {
    int n = 5;
    int k = 3;
    List<TreeSet<Integer>> result = ArrayCombination.combination(n, k);
    assertNotNull(result);
    assertEquals(10, result.size());
  }
  @Test
  @Tag("Boundary") 
  void testCombinationWithZeroIntegers() {
    int n = 0;
    int k = 3;
    List<TreeSet<Integer>> result = ArrayCombination.combination(n, k);
    assertNull(result);
  }
  @Test
  @Tag("Invalid") 
  void testCombinationWithNegativeIntegers() {
    int n = -5;
    int k = 3;
    List<TreeSet<Integer>> result = ArrayCombination.combination(n, k);
    assertNull(result);
  }
  @Test
  @Tag("Boundary") 
  void testCombinationWithKGreaterThanN() {
    int n = 3;
    int k = 5;
    List<TreeSet<Integer>> result = ArrayCombination.combination(n, k);
    assertNotNull(result);
    assertTrue(result.isEmpty());
  }
}
